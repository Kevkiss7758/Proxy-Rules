# ============================================================
# Garry 自定义 Proxy 规则集 0505
# ============================================================
# 用途：
# 1. 收纳个人确认需要走国际流量的域名。
# 2. 适合境外网站、订阅服务、下载服务、特殊站点。
# 3. 不确定是否需要代理的域名不收录。
# ============================================================


# =========================
# 1. 机场 / 订阅 / 面板相关
# =========================

DOMAIN-SUFFIX,godya.cc
DOMAIN-SUFFIX,haoya.io

# =========================
# 2. 基础网络探测与连通性测试
# =========================
IP-CIDR,8.8.8.8/32,no-resolve

# =========================
# 4. 跨国支付网关与反欺诈风控
# =========================
# 备注：保障海外内购、绑卡环境的 IP 一致性，防止触发风控锁号或阻断。
DOMAIN-SUFFIX,braintreegateway.com
DOMAIN-SUFFIX,perimeterx.net


# =========================
# 4. Nvidia / 特殊服务
# =========================

DOMAIN,faka.nvidia.rip


# =========================
# 5. 软件 / 工具 / 下载
# =========================

DOMAIN-SUFFIX,hibitsoft.ir
DOMAIN-SUFFIX,df11faces.com
DOMAIN,whatshub.top


# =========================
# 6. 媒体 / 影视 / 观影记录
# =========================

DOMAIN-SUFFIX,missav.ai
DOMAIN-SUFFIX,trakt.tv


# =========================
# 7. 空气质量 / 境外服务
# =========================

DOMAIN-SUFFIX,airvisual.com



